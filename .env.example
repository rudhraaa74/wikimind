# API Keys
GOOGLE_API_KEY="your_google_api_key_here"
OPENROUTER_API_KEY="your_openrouter_api_key_here"
PINECONE_API_KEY="your_pinecone_api_key_here"

# Neo4j AuraDB Config
NEO4J_URI="neo4j+s://your_db_id.databases.neo4j.io"
NEO4J_USERNAME="neo4j"
NEO4J_PASSWORD="your_neo4j_password_here"

# Vector DB Config
PINECONE_INDEX_NAME="wikimind"
PINECONE_HOST="https://wikimind-your_pinecone_host.svc.pinecone.io"

# OpenRouter Model Configs
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"

# Application Config
BACKEND_URL="http://backend:8000"
LOG_FILE_PATH="backend_logs/wikimind.log"
MAX_ARTICLES="4"
CHUNK_SIZE="500"
CHUNK_OVERLAP="50"
